{
  "name": "system2",
  "version": "0.1.0",
  "private": true,
  "description": "A multi-agent data platform for solo analysts",
  "repository": {
    "type": "git",
    "url": "https://github.com/diegoscarabelli/system2.git"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
